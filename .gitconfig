[core]
	editor = nvim
	ignorecase = false
	excludesfile = ~/.config/git/ignore

[push]
	default = simple
	autoSetupRemote = true

[color]
	status = auto
	diff = auto
	branch = auto

[ghq]
	root = ~/.ghq

[credential]
	helper = !~/Dev/dotfiles/scripts/git-credential-helper.sh

# Personal name/email live in ~/.gitconfig.local (not committed)
[include]
	path = ~/.gitconfig.local
[credential "https://dev.azure.com"]
	useHttpPath = true
[pull]
	rebase = true
