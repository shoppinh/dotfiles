# --- Appearance & Performance ---
theme = TokyoNight Night
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 13
# Wider gamut on Apple Silicon; revert to srgb if colours look oversaturated
window-colorspace = display-p3
background-opacity = 1
background-blur-radius = 20
font-feature = -calt
font-thicken = true
adjust-cell-width = -7%
adjust-cell-height = 1%

# --- Cursor & UX ---
cursor-style = block
# Eliminates visual noise in Neovim
cursor-style-blink = false
shell-integration = fish
# Explicit control; drop sudo if not needed
shell-integration-features = cursor,sudo,title
mouse-hide-while-typing = true

# --- Clipboard ---
clipboard-read = allow
clipboard-write = allow
# Prevents trailing whitespace when pasting terminal output into editors
clipboard-trim-trailing-spaces = true

# --- Window Management ---
window-padding-x = 10
window-padding-y = 10
# Equalises padding on both sides of a split
window-padding-balance = true
window-decoration = true
window-save-state = default
# New splits/tabs open in current pane's cwd
window-inherit-working-directory = true
window-inherit-font-size = true
# Dim inactive splits for visual focus
unfocused-split-opacity = 0.85

# --- Keybindings (Vim-Friendly) ---
keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right

keybind = ctrl+shift+e=new_split:right
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+z=toggle_split_zoom

keybind = ctrl+shift+left=resize_split:left,20
keybind = ctrl+shift+right=resize_split:right,20
keybind = ctrl+shift+up=resize_split:up,20
keybind = ctrl+shift+down=resize_split:down,20

keybind = ctrl+shift+r=reload_config

macos-option-as-alt = true

# --- Performance ---
scrollback-limit = 10000
mouse-reporting = false
scrollbar = never